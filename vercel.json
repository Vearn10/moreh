{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/", "dest": "/index.php" },
    { "src": "/inquiry", "dest": "/inquiry.php" },
    { "src": "/send_email", "dest": "/send_email.php" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
