{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/", "dest": "index.php" },
    { "src": "/inquiry", "dest": "inquiry.php" },
    { "src": "/api/send_email", "dest": "api/send_email.php" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
